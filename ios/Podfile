require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

platform :ios, '15.0'
use_modular_headers!

prepare_react_native_project!

# 🚀 INDUSTRY-LEADING STABILITY ARCHITECTURE
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

global_config = use_native_modules!

# Centralized Professional Build Settings Factory
def apply_professional_settings(config, is_extension = false)
  s = config.build_settings

  # 1. SDK & Toolchain
  s['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
  s['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
  s['CLANG_CXX_LIBRARY'] = 'libc++'
  s['DEFINES_MODULE'] = 'YES'
  s['USE_HEADERMAP'] = 'NO'
  s['CLANG_ENABLE_MODULES'] = 'YES'

  # CRITICAL: Allow non-modular includes to bypass Xcode 16 strictness
  s['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

  # 2. Modern Linker Fix (Xcode 15/16)
  s['OTHER_LDFLAGS'] ||= ['$(inherited)']
  unless s['OTHER_LDFLAGS'].include?('-Wl,-ld_classic')
    s['OTHER_LDFLAGS'] << '-Wl,-ld_classic'
  end

  # 3. Absolute Warning Suppression (Production Safe)
  s['WARNING_CFLAGS'] = '-w -Xanalyzer -analyzer-disable-all'
  s['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
  s['RUN_CLANG_STATIC_ANALYZER'] = 'NO'
  s['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
  s['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

  # 4. Compiler Stability Flags
  s['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
  ['-w', '-fpermissive', '-Wno-everything', '-D_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'].each do |f|
    s['OTHER_CPLUSPLUSFLAGS'] << f unless s['OTHER_CPLUSPLUSFLAGS'].include?(f)
  end

  s['OTHER_CFLAGS'] ||= ['$(inherited)']
  ['-w', '-fpermissive', '-Wno-everything'].each do |f|
    s['OTHER_CFLAGS'] << f unless s['OTHER_CFLAGS'].include?(f)
  end

  # 5. Macro Polyfills
  s['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
  macro = 'UIControlEventValueChanged=(UIControlEvents)UIControlEventValueChanged'
  unless s['GCC_PREPROCESSOR_DEFINITIONS'].include?(macro)
    s['GCC_PREPROCESSOR_DEFINITIONS'] << macro
  end

  # 6. Compliance
  s['APPLICATION_EXTENSION_API_ONLY'] = is_extension ? 'YES' : 'NO'
  s['CODE_SIGNING_ALLOWED'] = 'NO'
end

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => flags[:hermes_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  # Linker: Isolate from React to satisfy Extension requirements
  use_frameworks! :linkage => :static
  pod 'OneSignalXCFramework', '3.12.10'
end

post_install do |installer|
  # 1. CocoaPods Privacy script bypass
  if defined?(PrivacyManifestUtils)
    PrivacyManifestUtils.singleton_class.define_method(:add_aggregated_privacy_manifest) do |_installer|
    end
  end

  # 2. React Native Standard Post Install
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  # 3. Surgical Target Hardening
  installer.pods_project.targets.each do |target|

    # Identify extension-related targets
    is_ext_pod = target.name.include?('OneSignal') || target.name.include?('NotificationService')

    target.build_configurations.each do |config|
      apply_professional_settings(config, is_ext_pod)
    end

    # TARGET SPECIFIC DE-CONFLICTION

    # Yoga: Aggressive removal of all compiler flags that override global suppression
    if target.name == 'Yoga'
      target.build_configurations.each do |config|
        config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CFLAGS'] << '-w' << '-Wno-everything'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-w' << '-Wno-everything'
      end
    end

    # fmt: Ensure compatibility
    if target.name == 'fmt'
      target.build_configurations.each do |config|
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-D_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'

        # FIX: Ensure fmt can find its own headers when built as a framework
        config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
        config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/fmt/include"'
        config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_TARGET_SRCROOT)/include"'
        config.build_settings['USE_HEADERMAP'] = 'NO'
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      end
    end

    # React-Core Headers: Eliminate the "Duplicate Output File" error
    if target.name.include?('CoreModulesHeaders')
      target.build_configurations.each do |config|
        config.build_settings['SKIP_INSTALL'] = 'YES'
        config.build_settings['PRODUCT_NAME'] = "ReactCoreRedundant"
      end
      # Wipe all build phases to prevent file collision in framework output
      target.build_phases.each do |phase|
        target.build_phases.delete(phase)
      end
    end

    # Bundle collision fix
    if target.name.include?('AccessibilityResources')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "Res_#{target.name.gsub(/[^0-9a-z]/i, '_')}"
      end
    end
  end

  # 4. Final Aggregator Synchronization
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      is_ext = target.name.include?('Extension')
      target.build_configurations.each do |config|
        apply_professional_settings(config, is_ext)
        # Purge React from Extension Linker
        if is_ext
           ld_flags = config.build_settings['OTHER_LDFLAGS'] || []
           config.build_settings['OTHER_LDFLAGS'] = ld_flags.reject { |f| f.to_s.include?('React') }
        end
      end
    end
    aggregate_target.user_project.save
  end
end
