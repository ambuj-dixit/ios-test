require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

# Fix for a critical bug in React Native 0.72 privacy manifest scripts
buggy_utils_path = File.expand_path('../node_modules/react-native/scripts/cocoapods/privacy_manifest_utils.rb', __dir__)
require buggy_utils_path if File.exist?(buggy_utils_path)

module PrivacyManifestUtils
  def self.add_aggregated_privacy_manifest(installer)
    Pod::UI.puts "[ESIM Fix] Bypassing buggy PrivacyManifestUtils".yellow
  end
end

platform :ios, '15.0'
use_modular_headers!

prepare_react_native_project!
$RNFirebaseAsStaticFramework = true

# Define config globally
global_config = use_native_modules!

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    :hermes_enabled => flags[:hermes_enabled],
    :fabric_enabled => flags[:fabric_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  pod 'OneSignalXCFramework', '>= 3.0', '< 5.0'
end

# PERMANENT ROOT-LEVEL FIX FOR ALL PODS
post_install do |installer|
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  installer.pods_project.targets.each do |target|
    # 1. DEDUPLICATION: Fix for 'Multiple commands produce AccessibilityResources.bundle'
    if target.name.include?('AccessibilityResources')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = target.name.gsub(/[.-]/, '_')
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end
    end

    # 2. SPECIFIC FIX: Force react-native-date-picker to ignore all errors and warnings
    if target.name.include?('react-native-date-picker')
      target.build_configurations.each do |config|
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['OTHER_CFLAGS'] = '$(inherited) -w'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -w'
      end
    end

    target.build_configurations.each do |build_config|
      # Force iOS 15.0
      build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # Force C++17
      build_config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'

      # Suppress all warnings globally
      build_config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'

      # Inject C++20 compatibility traits for Folly/Yoga/etc
      defs = build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      defs << '_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'
      defs << '_LIBCPP_ENABLE_CXX17_REMOVED_UNARY_BINARY_FUNCTION=1'
      build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

      # Linker stability
      build_config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
    end
  end
end
