require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

platform :ios, '15.0'
use_modular_headers!

prepare_react_native_project!

# 🚀 PROFESSIONAL GRADE CONFIGURATION
# Static linkage is highly recommended for React Native 0.72+ to avoid runtime header collisions
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

global_config = use_native_modules!

# Professional Build Settings Factory
def apply_professional_settings(config, is_extension = false)
  # Standardize Deployment Target
  config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

  # C++ Standard Compliance (Critical for Reanimated and Yoga)
  config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
  config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'

  # Module & Header Safety
  config.build_settings['DEFINES_MODULE'] = 'YES'
  config.build_settings['USE_HEADERMAP'] = 'NO'
  config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
  config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'

  # Linker Fixes for Xcode 15/16
  config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_LDFLAGS'] << '-Wl,-ld_classic'

  # Warning Suppression (Zero Failure Policy for Warnings)
  config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
  config.build_settings['RUN_CLANG_STATIC_ANALYZER'] = 'NO'
  config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
  config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

  # Performance & Architecture
  config.build_settings['ENABLE_BITCODE'] = 'NO'
  config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'

  # RN 0.72+ Specific Compiler Flags
  config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-w' << '-fpermissive' << '-Wno-everything' << '-D_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'

  config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_CFLAGS'] << '-w' << '-fpermissive' << '-Wno-everything'

  # Universal Macros
  defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
  defs << 'UIControlEventValueChanged=(UIControlEvents)UIControlEventValueChanged'
  config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs.uniq

  # Extension Compliance
  config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = is_extension ? 'YES' : 'NO'
end

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    # Hermes is professionally recommended for better performance and debugging
    :hermes_enabled => true,
    :fabric_enabled => flags[:fabric_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  use_frameworks! :linkage => :static
  pod 'OneSignalXCFramework', '3.12.10'
end

post_install do |installer|
  # 1. CocoaPods 1.15+ Privacy Manifest Workaround
  if defined?(PrivacyManifestUtils)
    PrivacyManifestUtils.singleton_class.define_method(:add_aggregated_privacy_manifest) do |_installer|
    end
  end

  # 2. Standard React Native Post Install Logic
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  # 3. Surgical Target Optimization
  installer.pods_project.targets.each do |target|

    # Fix 1: Yoga Compilation (Force non-strict mode)
    if target.name == 'Yoga'
      target.build_configurations.each do |config|
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-all' << '-Wno-error' << '-Wno-extra'
      end
    end

    # Fix 2: React-Core Header Collision (Surgical Removal)
    if target.name.include?('React-Core.common-CoreModulesHeaders')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "ReactCoreHeaders"
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end
      target.build_phases.each do |phase|
        if phase.is_a?(Xcodeproj::Project::Object::PBXHeadersBuildPhase)
          phase.files.each do |header|
            if header.file_ref && header.file_ref.respond_to?(:path) && header.file_ref.path
              filename = File.basename(header.file_ref.path)
              duplicates = ['RCTVirtualTextShadowView.h', 'RCTVirtualTextViewManager.h', 'RCTWrapperViewController.h', 'UIView+Private.h', 'UIView+React.h', 'RCTViewUtils.h']
              phase.remove_build_file(header) if duplicates.include?(filename)
            end
          end
        end
      end
    end

    # Fix 3: Bundle Name Collisions (Accessibility Resources)
    if target.name.include?('AccessibilityResources')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "Res_#{target.name.gsub(/[^0-9a-z]/i, '_')}"
      end
    end

    # Fix 4: Apply Global Professional Settings
    is_ext_pod = target.name.include?('OneSignal') || target.name.include?('NotificationService')
    target.build_configurations.each do |config|
      apply_professional_settings(config, is_ext_pod)
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end

  # 4. Final Aggregator Synchronization
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      is_ext = target.name.include?('Extension')
      target.build_configurations.each do |config|
        apply_professional_settings(config, is_ext)

        # Purge React dependencies from Extension targets (Architecture Constraint)
        if is_ext
           ld_flags = config.build_settings['OTHER_LDFLAGS'] || []
           config.build_settings['OTHER_LDFLAGS'] = ld_flags.reject { |flag| flag.include?('React') }
        end
      end
    end
    aggregate_target.user_project.save
  end
end
