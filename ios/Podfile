require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

platform :ios, '15.0'
use_modular_headers!

prepare_react_native_project!

# 🚀 WORLD-CLASS CONFIGURATION FOR REACT NATIVE 0.72+
# Static frameworks are essential for Firebase and OneSignal in modern RN
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

global_config = use_native_modules!

# Professional Build Settings Function
def apply_professional_settings(config, is_extension = false)
  # 1. Base Consistency
  config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
  config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
  config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
  config.build_settings['DEFINES_MODULE'] = 'YES'
  config.build_settings['USE_HEADERMAP'] = 'NO'

  # 2. CI Stability & Silence Warnings
  config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
  config.build_settings['RUN_CLANG_STATIC_ANALYZER'] = 'NO'
  config.build_settings['COPY_PHASE_STRIP'] = 'NO'

  # 3. New Linker Workaround (Xcode 15+)
  config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_LDFLAGS'] << '-Wl,-ld_classic'

  # 4. React Native 0.72+ C++ Compatibility
  config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-w' << '-fpermissive' << '-Wno-everything' << '-D_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'

  config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
  config.build_settings['OTHER_CFLAGS'] << '-w' << '-fpermissive' << '-Wno-everything'

  # 5. UIControlEventValueChanged Casting Macro
  defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
  defs << 'UIControlEventValueChanged=(UIControlEvents)UIControlEventValueChanged'
  config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs.uniq

  # 6. CRITICAL: Application Extension API Compliance
  # Main App = NO, Extensions = YES. All libraries linked to extension must be YES.
  config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = is_extension ? 'YES' : 'NO'
end

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    :hermes_enabled => flags[:hermes_enabled],
    :fabric_enabled => flags[:fabric_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  # Linker: Static linkage for extension dependencies
  use_frameworks! :linkage => :static
  pod 'OneSignalXCFramework', '3.12.10'
end

post_install do |installer|
  # 1. Privacy Manifest Bypass (CocoaPods 1.15+ issue)
  if defined?(PrivacyManifestUtils)
    PrivacyManifestUtils.singleton_class.define_method(:add_aggregated_privacy_manifest) do |_installer|
    end
  end

  # 2. Standard React Native Post Install
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  # 3. Iterate through all Pod targets
  installer.pods_project.targets.each do |target|
    # Determine if this pod is used by the extension
    is_extension_pod = target.name.include?('OneSignal') || target.name.include?('NotificationService')

    target.build_configurations.each do |config|
      apply_professional_settings(config, is_extension_pod)

      # CI Fix: Disable code-signing for pods
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end

    # Fix for AccessibilityResources duplicate bundle
    if target.name.include?('AccessibilityResources')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "Res_#{target.name.gsub(/[^0-9a-z]/i, '_')}"
      end
    end
  end

  # 4. Enforce settings on Main Project Targets
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      is_ext = target.name.include?('Extension')
      target.build_configurations.each do |config|
        apply_professional_settings(config, is_ext)

        # Additional Linker Ambiguity Fix for Extensions
        if is_ext
           # Remove implicit React framework linking if it causes ambiguity
           ld_flags = config.build_settings['OTHER_LDFLAGS'] || []
           if ld_flags.include?('-framework "React"') || ld_flags.include?('-framework React')
             config.build_settings['OTHER_LDFLAGS'].delete('-framework "React"')
             config.build_settings['OTHER_LDFLAGS'].delete('-framework React')
           end
        end
      end
    end
    aggregate_target.user_project.save
  end
end
