require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

# Fix for React Native 0.72 privacy manifest scripts
buggy_utils_path = File.expand_path('../node_modules/react-native/scripts/cocoapods/privacy_manifest_utils.rb', __dir__)
require buggy_utils_path if File.exist?(buggy_utils_path)

module PrivacyManifestUtils
  def self.add_aggregated_privacy_manifest(installer)
    Pod::UI.puts "[ESIM Fix] Bypassing buggy PrivacyManifestUtils".yellow
  end
end

platform :ios, '15.0'
use_modular_headers!

prepare_react_native_project!
$RNFirebaseAsStaticFramework = true

global_config = use_native_modules!

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    :hermes_enabled => flags[:hermes_enabled],
    :fabric_enabled => flags[:fabric_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  pod 'OneSignalXCFramework', '>= 3.0', '< 5.0'
end

post_install do |installer|
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  # THE OMEGA DEDUPLICATION: Remove the duplicate AccessibilityResources target
  installer.pods_project.targets.each do |target|
    if target.name == 'React-Core.common-CoreModulesHeaders-AccessibilityResources'
        Pod::UI.puts "[ESIM Fix] Destroying duplicate bundle target: #{target.name}".red
        target.remove_from_project
    end
  end

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'

      defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      defs << '_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'
      defs << '_LIBCPP_ENABLE_CXX17_REMOVED_UNARY_BINARY_FUNCTION=1'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
      config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -w'
    end
  end
end
