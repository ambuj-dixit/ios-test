require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

platform :ios, '15.0'
prepare_react_native_project!

# 🚀 PROFESSIONAL GRADE CONFIGURATION
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

global_config = use_native_modules!

def apply_professional_settings(config, is_extension = false)
  # Ensure we are working with the actual settings hash
  settings = config.build_settings

  settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
  settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
  settings['DEFINES_MODULE'] = 'YES'
  settings['USE_HEADERMAP'] = 'NO'
  settings['CLANG_ENABLE_MODULES'] = 'YES'

  # Linker Fix (Xcode 15+)
  ld_flags = settings['OTHER_LDFLAGS'] || ['$(inherited)']
  ld_flags << '-Wl,-ld_classic' unless ld_flags.include?('-Wl,-ld_classic')
  settings['OTHER_LDFLAGS'] = ld_flags

  # Warning Management
  settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
  settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
  settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
  settings['RUN_CLANG_STATIC_ANALYZER'] = 'NO'

  # C++ Flags
  cpp_flags = settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
  ['-w', '-fpermissive', '-Wno-everything', '-D_LIBCPP_ENABLE_CXX20_REMOVED_TYPE_TRAITS=1'].each do |f|
    cpp_flags << f unless cpp_flags.include?(f)
  end
  settings['OTHER_CPLUSPLUSFLAGS'] = cpp_flags

  # C Flags
  c_flags = settings['OTHER_CFLAGS'] || ['$(inherited)']
  ['-w', '-fpermissive', '-Wno-everything'].each do |f|
    c_flags << f unless c_flags.include?(f)
  end
  settings['OTHER_CFLAGS'] = c_flags

  # Preprocessor
  defs = settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
  macro = 'UIControlEventValueChanged=(UIControlEvents)UIControlEventValueChanged'
  defs << macro unless defs.include?(macro)
  settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

  settings['APPLICATION_EXTENSION_API_ONLY'] = is_extension ? 'YES' : 'NO'
  settings['CODE_SIGNING_ALLOWED'] = 'NO'
end

target 'Esimcampus' do
  flags = get_default_flags()

  use_react_native!(
    :path => global_config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => flags[:hermes_enabled],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'EsimcampusTests' do
    inherit! :complete
  end
end

target 'OneSignalNotificationServiceExtension' do
  use_frameworks! :linkage => :static
  pod 'OneSignalXCFramework', '3.12.10'
end

post_install do |installer|
  # 1. CocoaPods 1.15+ Privacy Fix
  if defined?(PrivacyManifestUtils)
    PrivacyManifestUtils.singleton_class.define_method(:add_aggregated_privacy_manifest) do |_installer|
    end
  end

  # 2. Standard React Native Post Install
  react_native_post_install(
    installer,
    global_config[:reactNativePath],
    :mac_catalyst_enabled => false
  )

  # 3. Surgical Target Optimization
  installer.pods_project.targets.each do |target|
    is_ext_pod = target.name.include?('OneSignal') || target.name.include?('NotificationService')

    target.build_configurations.each do |config|
      apply_professional_settings(config, is_ext_pod)
    end

    # Fix for React-Core Collision (The duplicate output file error)
    if target.name.include?('React-Core.common-CoreModulesHeaders')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "ReactCoreHeaders"
        config.build_settings['MODULE_NAME'] = "ReactCoreHeaders"
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end
    end

    if target.name.include?('AccessibilityResources')
      target.build_configurations.each do |config|
        config.build_settings['PRODUCT_NAME'] = "Res_#{target.name.gsub(/[^0-9a-z]/i, '_')}"
      end
    end
  end

  # 4. Final Aggregator Sync
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      is_ext = target.name.include?('Extension')
      target.build_configurations.each do |config|
        apply_professional_settings(config, is_ext)
        if is_ext
           # Aggressive removal of React from Extension Linker to satisfy APPLICATION_EXTENSION_API_ONLY
           ld_flags = config.build_settings['OTHER_LDFLAGS'] || []
           config.build_settings['OTHER_LDFLAGS'] = ld_flags.reject { |flag| flag.to_s.include?('React') }
        end
      end
    end
    aggregate_target.user_project.save
  end
end
